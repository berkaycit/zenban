#!/usr/bin/env bash

debug_log_path="${ZENBAN_AGENT_LIFECYCLE_LOG:-/tmp/zenban-agent-lifecycle.log}"

debug_log() {
    local timestamp
    timestamp="$(date '+%Y-%m-%dT%H:%M:%S%z')"
    printf '%s [codex-wrapper] %s\n' "$timestamp" "$*" >> "$debug_log_path" 2>/dev/null || true
}

find_real_codex() {
    local self_dir
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    local IFS=:
    for d in $PATH; do
        [[ "$d" == "$self_dir" ]] && continue
        [[ -x "$d/codex" ]] && printf '%s' "$d/codex" && return 0
    done
    return 1
}

shell_quote() {
    local value="$1"
    value=${value//\'/\'\"\'\"\'}
    printf "'%s'" "$value"
}

build_agent_hook_command() {
    local self_dir cmux_bin workspace_id surface_id command
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    cmux_bin="$self_dir/cmux"
    workspace_id="${CMUX_WORKSPACE_ID:-${CMUX_TAB_ID:-}}"
    surface_id="${CMUX_SURFACE_ID:-${CMUX_PANEL_ID:-}}"

    command="$(shell_quote "$cmux_bin") agent-hook codex completed"
    if [[ -n "$workspace_id" ]]; then
        command+=" --workspace $(shell_quote "$workspace_id")"
    fi
    if [[ -n "$surface_id" ]]; then
        command+=" --surface $(shell_quote "$surface_id")"
    fi

    printf '%s' "$command"
}

cmux_socket_available() {
    local socket="${CMUX_SOCKET_PATH:-}"
    [[ -n "$socket" && -S "$socket" ]] || return 1

    local self_dir cmux_bin
    self_dir="$(cd "$(dirname "$0")" && pwd)"
    cmux_bin="$self_dir/cmux"
    [[ -x "$cmux_bin" ]] || cmux_bin="$(command -v cmux || true)"
    [[ -n "$cmux_bin" ]] || return 1
    return 0
}

should_passthrough_subcommand() {
    case "${1:-}" in
        exec|review|login|logout|mcp|mcp-server|app-server|app|completion|sandbox|debug|apply|cloud|features|help)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

in_cmux=0
if [[ -n "${CMUX_SURFACE_ID:-}" ]]; then
    in_cmux=1
fi

real_codex="$(find_real_codex)" || { echo "Error: codex not found in PATH" >&2; exit 127; }

socket_ready=0
if cmux_socket_available; then
    socket_ready=1
fi

debug_log \
    "start in_cmux=$in_cmux socket_ready=$socket_ready hooks_disabled=${CMUX_CODEX_HOOKS_DISABLED:-0} " \
    "workspace=${CMUX_WORKSPACE_ID:-${CMUX_TAB_ID:-nil}} surface=${CMUX_SURFACE_ID:-${CMUX_PANEL_ID:-nil}} argv0=${1:-}"

if [[ "$in_cmux" == "0" || "${CMUX_CODEX_HOOKS_DISABLED:-0}" == "1" || "$socket_ready" == "0" ]]; then
    debug_log "passthrough in_cmux=$in_cmux socket_ready=$socket_ready hooks_disabled=${CMUX_CODEX_HOOKS_DISABLED:-0}"
    exec "$real_codex" "$@"
fi

if should_passthrough_subcommand "${1:-}"; then
    debug_log "passthrough reason=subcommand subcommand=${1:-}"
    exec "$real_codex" "$@"
fi

hook_command="$(build_agent_hook_command)"
notify_config='notify=["/bin/bash","-lc","'"$hook_command"'"]'
debug_log "inject hook_command=$hook_command"

exec "$real_codex" -c "$notify_config" "$@"
