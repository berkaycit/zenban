#!/usr/bin/env bash
set -euo pipefail

DEFAULT_SOCKET_PATH="/tmp/cmux.sock"
socket_path="${CMUX_SOCKET_PATH:-$DEFAULT_SOCKET_PATH}"
timeout_seconds="${CMUXTERM_CLI_RESPONSE_TIMEOUT_SEC:-2}"

normalize_timeout() {
    local value="$1"
    value="${value%%.*}"
    if [[ -z "$value" || "$value" -lt 1 ]]; then
        value=1
    fi
    printf '%s' "$value"
}

usage() {
    cat <<'EOF'
Usage:
  cmux [--socket PATH] ping
  cmux [--socket PATH] browser open <url>
  cmux [--socket PATH] claude-hook <session-start|active|stop|idle|notification|notify|prompt-submit> [--workspace ID] [--surface ID]
EOF
}

socket_quote() {
    local value="$1"
    value=${value//\'/\'\"\'\"\'} 
    printf "'%s'" "$value"
}

send_socket_command() {
    local command="$1"
    local timeout
    timeout="$(normalize_timeout "$timeout_seconds")"

    if [[ -z "$socket_path" || ! -S "$socket_path" ]]; then
        echo "socket unavailable: $socket_path" >&2
        return 1
    fi

    printf '%s' "$command" | nc -U -w "$timeout" "$socket_path"
}

workspace_id_from_env() {
    if [[ -n "${CMUX_WORKSPACE_ID:-}" ]]; then
        printf '%s' "$CMUX_WORKSPACE_ID"
        return 0
    fi
    if [[ -n "${CMUX_TAB_ID:-}" ]]; then
        printf '%s' "$CMUX_TAB_ID"
        return 0
    fi
    return 1
}

surface_id_from_env() {
    if [[ -n "${CMUX_SURFACE_ID:-}" ]]; then
        printf '%s' "$CMUX_SURFACE_ID"
        return 0
    fi
    if [[ -n "${CMUX_PANEL_ID:-}" ]]; then
        printf '%s' "$CMUX_PANEL_ID"
        return 0
    fi
    return 1
}

read_stdin_base64() {
    local payload
    payload="$(cat || true)"
    if [[ -z "$payload" ]]; then
        return 0
    fi
    printf '%s' "$payload" | base64 | tr -d '\n'
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --socket)
            [[ $# -ge 2 ]] || { echo "--socket requires a path" >&2; exit 1; }
            socket_path="$2"
            shift 2
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

[[ $# -gt 0 ]] || { usage >&2; exit 1; }

command="$1"
shift

case "$command" in
    ping|system.ping)
        send_socket_command "ping"
        ;;

    browser)
        [[ $# -gt 0 ]] || { usage >&2; exit 1; }
        browser_command="$1"
        shift
        case "$browser_command" in
            open|open-split)
                [[ $# -gt 0 ]] || { echo "browser $browser_command requires a URL" >&2; exit 1; }
                url="$1"
                shift
                workspace_id="$(workspace_id_from_env || true)"
                surface_id="$(surface_id_from_env || true)"
                socket_command="open_url $(socket_quote "$url")"
                if [[ -n "$workspace_id" ]]; then
                    socket_command+=" --tab=$workspace_id"
                fi
                if [[ -n "$surface_id" ]]; then
                    socket_command+=" --panel=$surface_id"
                fi
                send_socket_command "$socket_command"
                ;;
            *)
                echo "unsupported browser subcommand: $browser_command" >&2
                exit 1
                ;;
        esac
        ;;

    claude-hook)
        [[ $# -gt 0 ]] || { echo "claude-hook requires a subcommand" >&2; exit 1; }
        hook_subcommand="$1"
        shift
        workspace_id="${CMUX_WORKSPACE_ID:-${CMUX_TAB_ID:-}}"
        surface_id="${CMUX_SURFACE_ID:-${CMUX_PANEL_ID:-}}"
        while [[ $# -gt 0 ]]; do
            case "$1" in
                --workspace|--tab)
                    [[ $# -ge 2 ]] || { echo "$1 requires a value" >&2; exit 1; }
                    workspace_id="$2"
                    shift 2
                    ;;
                --surface|--panel)
                    [[ $# -ge 2 ]] || { echo "$1 requires a value" >&2; exit 1; }
                    surface_id="$2"
                    shift 2
                    ;;
                --help|-h)
                    usage
                    exit 0
                    ;;
                *)
                    echo "unsupported claude-hook option: $1" >&2
                    exit 1
                    ;;
            esac
        done
        [[ -n "$workspace_id" ]] || { echo "claude-hook requires CMUX_WORKSPACE_ID/CMUX_TAB_ID or --workspace" >&2; exit 1; }
        payload_b64="$(read_stdin_base64)"
        socket_command="claude_hook $(socket_quote "$hook_subcommand")"
        if [[ -n "$payload_b64" ]]; then
            socket_command+=" $(socket_quote "$payload_b64")"
        fi
        socket_command+=" --tab=$workspace_id"
        if [[ -n "$surface_id" ]]; then
            socket_command+=" --panel=$surface_id"
        fi
        send_socket_command "$socket_command"
        ;;

    *)
        echo "unsupported command: $command" >&2
        exit 1
        ;;
esac
