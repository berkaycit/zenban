    "cli.claude-teams.usage" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usage: zenban claude-teams [claude-args...]\n\nLaunch Claude Code with agent teams enabled.\n\nThis command:\n  - defaults Claude teammate mode to auto\n  - sets a tmux-like environment so Claude auto mode uses Zenban splits\n  - sets CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1\n  - prepends a private tmux shim to PATH\n  - forwards all remaining arguments to claude\n\nThe tmux shim translates supported tmux window/pane commands into Zenban\nworkspace and split operations in the current Zenban session.\n\nExamples:\n  zenban claude-teams\n  zenban claude-teams --continue\n  zenban claude-teams --model sonnet"
          }
        }
      }
    },
    "cli.install.adminRequired" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Administrator privileges were required to write to /usr/local/bin."
          }
        }
      }
